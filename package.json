{
  "name": "eslint-plugin-llm-core",
  "version": "0.5.0",
  "description": "ESLint rules that catch the patterns LLM agents get wrong — and teach them to self-correct",
  "license": "MIT",
  "author": "Rob Simpson <rsimpson2@me.com>",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin",
    "llm",
    "ai",
    "linting",
    "typescript",
    "code-quality",
    "static-analysis",
    "chatgpt",
    "copilot",
    "claude",
    "ai-generated-code"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pertrai1/eslint-plugin-llm-core.git"
  },
  "homepage": "https://github.com/pertrai1/eslint-plugin-llm-core#readme",
  "bugs": {
    "url": "https://github.com/pertrai1/eslint-plugin-llm-core/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "update:eslint-docs": "eslint-doc-generator",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "npm run build && changeset publish"
  },
  "peerDependencies": {
    "@typescript-eslint/utils": "^8.0.0",
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.27.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.5.0",
    "@typescript-eslint/rule-tester": "^8.0.0",
    "@typescript-eslint/utils": "^8.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-doc-generator": "^2.0.0",
    "eslint-plugin-eslint-plugin": "^6.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.2"
  }
}
